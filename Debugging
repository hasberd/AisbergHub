-- Скроллируемая область
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -20, 1, -90)
scroll.Position = UDim2.new(0, 10, 0, 80)
scroll.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 6
scroll.ScrollBarImageColor3 = Color3.fromRGB(120, 120, 120)
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.Parent = main

local listLayout = Instance.new("UIListLayout")
listLayout.FillDirection = Enum.FillDirection.Vertical
listLayout.SortOrder = Enum.SortOrder.LayoutOrder
listLayout.Padding = UDim.new(0, 2)
listLayout.Parent = scroll

local function updateCanvasSize()
    scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvasSize)

local lines = {}

local function appendLine(text)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, -4, 0, 16)
    label.Font = Enum.Font.Code
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.TextWrapped = false
    label.Text = text
    label.TextSize = 14
    label.TextColor3 = Color3.fromRGB(0, 255, 0)
    label.Parent = scroll

    table.insert(lines, label)
    updateCanvasSize()
    scroll.CanvasPosition = Vector2.new(0, math.max(scroll.CanvasSize.Y.Offset - scroll.AbsoluteSize.Y, 0))
end

clearBtn.MouseButton1Click:Connect(function()
    for _, l in ipairs(lines) do
        l:Destroy()
    end
    lines = {}
    updateCanvasSize()
end)

--------------------------------------------------
-- Ресайз окна (за правый‑нижний угол)
--------------------------------------------------

local resizeHandle = Instance.new("Frame")
resizeHandle.Size = UDim2.new(0, 14, 0, 14)
resizeHandle.Position = UDim2.new(1, -14, 1, -14)
resizeHandle.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
resizeHandle.BorderSizePixel = 0
resizeHandle.Parent = main

local resizing = false
local resizeStartPos
local resizeStartSize

resizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true
        resizeStartPos = UIS:GetMouseLocation()
        resizeStartSize = main.Size
    end
end)

resizeHandle.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
        local currentPos = UIS:GetMouseLocation()
        local delta = currentPos - resizeStartPos

        local newW = math.max(320, resizeStartSize.X.Offset + delta.X)
        local newH = math.max(200, resizeStartSize.Y.Offset + delta.Y)
        main.Size = UDim2.new(0, newW, 0, newH)
    end
end)

--------------------------------------------------
-- Логика сканирования PlaytimeRewards
--------------------------------------------------

local running = false

local function startScanner()
    if running then return end
    running = true
    startBtn.Text = "Stop Playtime Debug"
    startBtn.BackgroundColor3 = Color3.fromRGB(150, 60, 60)

    appendLine("[Start] Playtime debug started")

    local ok, err = pcall(function()
        local pg = LocalPlayer:WaitForChild("PlayerGui")
        local mainUi = pg:WaitForChild("Main_User_Interface")
        local rewardsRoot = mainUi:WaitForChild("Rewards")
        local playtime = rewardsRoot:WaitForChild("PlaytimeRewards")

        local rewardsFolder = playtime:FindFirstChild("Rewards") or playtime

        appendLine("[Info] Using folder: " .. rewardsFolder.Name)

        local rewardButtons = {}

        for _, tierFrame in ipairs(rewardsFolder:GetChildren()) do
            if tierFrame:IsA("Frame") then
                local btn = tierFrame:FindFirstChild("Button")
                if btn and btn:IsA("GuiButton") then
                    local txtLabel = btn:FindFirstChild("Frame") and btn.Frame:FindFirstChild("TextLabel")
                    local claimedGui = btn:FindFirstChild("Claimed")
                    table.insert(rewardButtons, {
                        Tier    = tierFrame.Name,
                        Button  = btn,
                        Label   = txtLabel,
                        Claimed = claimedGui
                    })
                    appendLine(string.format(
                        "[Found] Tier=%s Label=%s HasClaimed=%s",
                        tierFrame.Name,
                        txtLabel and txtLabel.Text or "nil",
                        tostring(claimedGui ~= nil)
                    ))
                end
            end
        end

        if #rewardButtons == 0 then
            appendLine("[Warn] No reward buttons found")
            return
        end

        task.spawn(function()
            while running do
                task.wait(1)
                for _, info in ipairs(rewardButtons) do
                    local btn     = info.Button
                    local lbl     = info.Label
                    local claimed = info.Claimed

                    if btn and btn.Parent and btn.Parent.Visible and btn.Visible then
                        local text = lbl and lbl.Text or "nil"
                        local claimedVisible = claimed and claimed.Visible or false
                        local line = string.format(
                            "[State] Tier=%s Text=%s Claimed.Visible=%s Active=%s",
                            info.Tier,
                            text,
                            tostring(claimedVisible),
                            tostring(btn.Active)
                        )
                        appendLine(line)
                    end
                end
            end
            appendLine("[Stop] Playtime debug stopped")
        end)
    end)

    if not ok then
        appendLine("[Error] Init: " .. tostring(err))
        running = false
        startBtn.Text = "Start Playtime Debug"
        startBtn.BackgroundColor3 = Color3.fromRGB(50, 130, 50)
    end
end

local function stopScanner()
    if not running then return end
    running = false
    startBtn.Text = "Start Playtime Debug"
    startBtn.BackgroundColor3 = Color3.fromRGB(50, 130, 50)
end

startBtn.MouseButton1Click:Connect(function()
    if running then
        stopScanner()
    else
        startScanner()
    end
end)
